# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amazon_store
DB_USER=root
DB_PASSWORD=your_password_here

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Origins (comma-separated for multiple domains)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Cloudinary (Optional - for production image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration (Resend/SendGrid)
EMAIL_SERVICE=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379
